# ============================================================================
#  Hànlù AI Tutor — backend environment variables
# ----------------------------------------------------------------------------
#  Copy this file to .env.local for local dev, and set the SAME variables in
#  Vercel → Project → Settings → Environment Variables for production.
#
#  ⚠️  NEVER commit a real key. .env and .env.local are gitignored.
#  ⚠️  These are used ONLY by the serverless function (api/chat.js).
#      They are never shipped to the browser.
# ============================================================================

# Which provider to use: "anthropic" (recommended, default) or "openai"
AI_PROVIDER=anthropic

# --- Anthropic (used when AI_PROVIDER=anthropic) ---------------------------
# Get a key at https://console.anthropic.com  → API Keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- OpenAI (used when AI_PROVIDER=openai) ----------------------------------
# Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Model (optional) -------------------------------------------------------
# Leave unset to use the per-provider default:
#   anthropic default: claude-opus-4-8   (highest quality)
#   openai    default: gpt-4o-mini
#
# 💰 COST TIP: a vocabulary tutor does NOT need the most expensive model.
#    For a student app with lots of messages, set:
#       AI_MODEL=claude-haiku-4-5     (~5x cheaper than Opus, still excellent)
#    Other options: claude-sonnet-4-6 (balanced), claude-opus-4-8 (top quality).
# AI_MODEL=claude-haiku-4-5

# --- CORS (optional) --------------------------------------------------------
# Comma-separated list of origins allowed to call this API.
# Defaults already include https://qodirovskiye.github.io and localhost:8777.
# Add your custom domain here if you have one. Use "*" only for quick testing.
# ALLOWED_ORIGINS=https://qodirovskiye.github.io,https://hanlu.example.com
